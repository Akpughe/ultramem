# UltraMem configuration. Copy to .env and fill in.

# Vector store (Qdrant). Local docker-compose uses http://qdrant:6333 with no key.
QDRANT_URL=https://your-qdrant-host:6333
QDRANT_API_KEY=

# Providers (HTTP APIs — no local ML).
JINA_API_KEY=          # embeddings + reranker (jina-embeddings-v3, jina-reranker-v2)
MISTRAL_API_KEY=       # OCR for PDFs + images (mistral-ocr-latest)
GROQ_API_KEY=          # LLM for planning + fact distillation (default provider)

# Swappable embedder (OSS-readiness). "jina" (default, 1024-dim) or "openai".
# When "openai", set OPENAI_API_KEY; the engine uses text-embedding-3-small
# (1536-dim). Switching embedders changes vector dimensionality, so use fresh
# collections (see ULTRAMEM collection names below). Any custom embedder can
# also be injected in code via MemoryEngine::with_embedder.
ULTRAMEM_EMBEDDER=jina
OPENAI_API_KEY=

# API auth. Set a strong secret; clients send `Authorization: Bearer <this>`.
# A bare key is treated as wildcard (may use any container_tag). To bind keys to
# specific namespaces, use ULTRAMEM_TENANTS instead, e.g.:
#   ULTRAMEM_TENANTS="keyA=tenant_a,shared; keyB=*"
# With NO key configured the server refuses to start unless ULTRAMEM_DEV=1
# (unauthenticated, local dev only).
ULTRAMEM_API_KEY=
# ULTRAMEM_TENANTS=
# ULTRAMEM_DEV=1

# Phase A source of truth (Postgres). UNSET → engine runs Qdrant-only, unchanged.
# When set, ingest dual-writes documents/chunks/memories/evidence, the timeline +
# search provenance are served from Postgres, and Qdrant becomes a rebuildable
# index (reindex mode=backfill / mode=rebuild). Recommended for production.
# Local docker-compose Postgres:
# ULTRAMEM_PG_URL=postgresql://ultramem:ultramem@postgres:5432/ultramem
# Fail fast instead of silently falling back to Qdrant-only if PG is unreachable:
# ULTRAMEM_PG_REQUIRED=1

# Object storage for original uploads (Task 2b). UNSET → originals aren't kept
# (only the extracted text). Set a directory to preserve uploaded file bytes so a
# document can be re-derived/downloaded; blob_key is recorded on the document row.
# ULTRAMEM_BLOB_DIR=/var/lib/ultramem/blobs

# Server port (default 8080).
PORT=8080
